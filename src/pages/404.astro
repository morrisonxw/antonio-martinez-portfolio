---
import PageLayout from '../layouts/PageLayout.astro';
import Container from '../components/ui/Container.astro';
import Button from '../components/ui/Button.astro';
---

<PageLayout title="Página no encontrada" description="La página que buscas no existe.">
  <Container class="flex min-h-[60vh] flex-col items-start justify-center py-24">
    <p class="text-sm font-medium text-accent">404</p>
    <h1 class="mt-3 font-display text-4xl font-bold text-ink sm:text-5xl">
      No encontramos esta página
    </h1>
    <p class="mt-4 text-ink-muted">Puede que el enlace esté roto o la página se haya movido.</p>
    <div class="mt-8">
      <Button href="/">Volver al inicio</Button>
    </div>
  </Container>
</PageLayout>
