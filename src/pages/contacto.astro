---
import { Image } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import Container from '../components/ui/Container.astro';
import Button from '../components/ui/Button.astro';
import { site } from '../content-data/site';
import profilePhoto from '../assets/profile/antonio.jpg';

const links = [
  { label: 'Teléfono', value: site.phone, href: `tel:${site.phone.replace(/\s+/g, '')}` },
  { label: 'Email', value: site.email, href: `mailto:${site.email}` },
  { label: 'LinkedIn', value: 'linkedin.com/in/ant-martinez', href: site.social.linkedin },
  { label: 'Behance', value: 'behance.net/jaidermartinez', href: site.social.behance },
];
---

<PageLayout title="Contacto" description={`Ponte en contacto con ${site.name}.`}>
  <Container class="pt-16 pb-24 sm:pt-20">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-[auto_1fr] sm:items-start">
      <Image
        src={profilePhoto}
        alt={site.name}
        width={160}
        height={160}
        class="h-32 w-32 rounded-full object-cover sm:h-40 sm:w-40"
      />

      <div class="max-w-[var(--prose-width)]">
        <p class="text-sm font-medium text-accent">Contacto</p>
        <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-ink sm:text-5xl">
          Hablemos
        </h1>
        <p class="mt-4 text-ink-muted">
          ¿Tienes un proyecto en mente o quieres charlar? Prefiero el contacto directo — escríbeme
          por WhatsApp o encuéntrame en cualquiera de estos canales.
        </p>

        <div class="mt-8">
          <Button href={site.whatsappUrl}>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
              <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.87 9.87 0 0 0 12.04 2m0 1.67c2.2 0 4.26.86 5.82 2.42a8.2 8.2 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.25 8.24a8.2 8.2 0 0 1-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.18 8.18 0 0 1-1.26-4.38c0-4.55 3.7-8.24 8.26-8.24m-4.7 4.73c-.16 0-.43.06-.65.31-.22.25-.86.84-.86 2.04 0 1.2.88 2.36 1 2.53.12.16 1.7 2.72 4.2 3.71 2.08.82 2.5.66 2.95.62.45-.04 1.46-.6 1.66-1.18.2-.58.2-1.07.14-1.18-.06-.1-.22-.16-.46-.28-.24-.12-1.46-.72-1.68-.8-.23-.09-.39-.13-.56.13-.16.25-.64.8-.78.97-.15.16-.29.18-.53.06-.24-.12-1.02-.38-1.94-1.2-.72-.64-1.2-1.44-1.35-1.68-.14-.24-.02-.37.1-.5.11-.1.24-.27.37-.4.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.56-1.36-.78-1.86-.2-.48-.4-.42-.56-.43z"/>
            </svg>
            WhatsApp
          </Button>
        </div>

        <ul class="mt-10 divide-y divide-border border-y border-border">
          {
            links.map((item) => (
              <li class="flex items-center justify-between py-4">
                <span class="text-sm text-ink-muted">{item.label}</span>
                <a
                  href={item.href}
                  target={item.href.startsWith('http') ? '_blank' : undefined}
                  rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                  class="font-medium text-ink hover:text-accent"
                >
                  {item.value}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Container>
</PageLayout>
