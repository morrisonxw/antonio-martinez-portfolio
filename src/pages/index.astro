---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import Container from '../components/ui/Container.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import ProjectGrid from '../components/project/ProjectGrid.astro';
import Button from '../components/ui/Button.astro';
import { site } from '../content-data/site';

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
const projectsToShow = featured.length > 0 ? featured : allProjects.slice(0, 4);
---

<PageLayout title={site.name} description={site.description}>
  <Container class="pt-20 pb-16 sm:pt-28 sm:pb-24">
    <p class="text-sm font-medium text-accent">{site.role}</p>
    <h1 class="mt-3 max-w-3xl font-display text-4xl font-bold tracking-tight text-ink sm:text-6xl">
      {site.tagline}
    </h1>
    <div class="mt-8 flex gap-4">
      <Button href="/proyectos">Ver proyectos</Button>
      <Button href="/sobre-mi" variant="secondary">Sobre mí</Button>
    </div>
  </Container>

  <Container class="pb-24">
    <SectionHeading eyebrow="Selección" class="mb-10">Proyectos destacados</SectionHeading>
    <ProjectGrid projects={projectsToShow} />
  </Container>
</PageLayout>
