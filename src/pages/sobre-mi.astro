---
import PageLayout from '../layouts/PageLayout.astro';
import Container from '../components/ui/Container.astro';
import Button from '../components/ui/Button.astro';
import Tag from '../components/ui/Tag.astro';
import { site } from '../content-data/site';
import { experience } from '../content-data/experience';
import { about } from '../content-data/about';
---

<PageLayout title="Sobre mí" description={`Conoce más sobre ${site.name}, ${site.role}.`}>
  <Container class="pt-16 pb-24 sm:pt-20">
    <div class="max-w-[var(--prose-width)]">
      <p class="text-sm font-medium text-accent">Sobre mí</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-ink sm:text-5xl">
        Hola, soy {site.name}.
      </h1>

      <div class="mt-8 space-y-8">
        {
          about.sections.map((section) => (
            <div>
              <h2 class="font-display text-lg font-bold text-ink">{section.heading}</h2>
              <p class="mt-2 text-ink-muted">{section.body}</p>
            </div>
          ))
        }
      </div>

      <div class="mt-10">
        <h2 class="font-display text-lg font-bold text-ink">Skills principales</h2>
        <div class="mt-3 flex flex-wrap gap-2">
          {about.skills.map((skill) => <Tag>{skill}</Tag>)}
        </div>
      </div>

      <div class="mt-10 flex gap-4">
        <Button href="/contacto">Contactarme</Button>
        <Button href="/proyectos" variant="secondary">Ver proyectos</Button>
      </div>
    </div>

    <div class="mt-20 max-w-[var(--prose-width)]">
      <h2 class="font-display text-2xl font-bold text-ink">Trayectoria</h2>
      <p class="mt-2 text-ink-muted">{about.experienceIntro}</p>
      <ul class="mt-6 divide-y divide-border border-y border-border">
        {
          experience.map((item) => (
            <li class="flex flex-col gap-1 py-5 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <p class="font-medium text-ink">{item.role}</p>
                <p class="text-sm text-ink-muted">{item.company}</p>
              </div>
              <span class="inline-flex w-fit items-center rounded-full border border-border px-3 py-1 text-xs font-medium text-ink-muted">
                {item.period}
              </span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="mt-20 max-w-[var(--prose-width)] border-l-2 border-accent pl-6">
      <p class="font-display text-xl font-medium text-ink sm:text-2xl">
        "{about.philosophy}"
      </p>
    </div>
  </Container>
</PageLayout>
