---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="my-10">
  <Image src={src} alt={alt} width={1200} class="w-full rounded-xl" />
  {caption && <figcaption class="mt-3 text-sm text-ink-muted">{caption}</figcaption>}
</figure>
