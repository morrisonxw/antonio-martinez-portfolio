---
interface Props {
  label: string;
  aspect?: 'video' | 'square' | 'wide';
}

const { label, aspect = 'video' } = Astro.props;
const aspectClass = {
  video: 'aspect-video',
  square: 'aspect-square',
  wide: 'aspect-[21/9]',
}[aspect];
---

<div
  class:list={[
    'my-10 flex w-full flex-col items-center justify-center gap-3 rounded-xl border-2 border-dashed border-border bg-paper-muted px-6 py-10 text-center',
    aspectClass,
  ]}
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-8 w-8 text-ink-muted">
    <rect x="3" y="3" width="18" height="18" rx="2" />
    <circle cx="8.5" cy="8.5" r="1.5" />
    <path d="M21 15l-5-5-9 9" />
  </svg>
  <p class="text-sm font-medium text-ink-muted">Imagen próximamente</p>
  {import.meta.env.DEV && <p class="max-w-md text-sm text-ink-muted">{label}</p>}
</div>
