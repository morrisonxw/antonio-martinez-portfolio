---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  before: ImageMetadata;
  beforeAlt: string;
  after: ImageMetadata;
  afterAlt: string;
}

const { before, beforeAlt, after, afterAlt } = Astro.props;
---

<div class="my-10 grid grid-cols-1 gap-4 sm:grid-cols-2">
  <figure>
    <Image src={before} alt={beforeAlt} width={800} class="w-full rounded-xl" />
    <figcaption class="mt-2 text-sm text-ink-muted">Antes</figcaption>
  </figure>
  <figure>
    <Image src={after} alt={afterAlt} width={800} class="w-full rounded-xl" />
    <figcaption class="mt-2 text-sm text-ink-muted">Después</figcaption>
  </figure>
</div>
