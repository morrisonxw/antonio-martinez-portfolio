---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<div class="my-10 grid grid-cols-1 gap-x-8 gap-y-8 sm:grid-cols-2">
  {
    stats.map((stat) => (
      <div>
        <p class="font-display text-4xl font-bold tracking-tight text-accent sm:text-5xl">
          {stat.value}
        </p>
        <p class="mt-2 text-sm text-ink-muted">{stat.label}</p>
      </div>
    ))
  }
</div>
