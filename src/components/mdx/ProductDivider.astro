---
interface Props {
  eyebrow: string;
  label: string;
}

const { eyebrow, label } = Astro.props;
---

<div class="relative my-14 -mx-6 rounded-md bg-ink px-6 py-6 sm:-mx-8 sm:px-8 dark:bg-paper-muted">
  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">{eyebrow}</p>
  <p class="mt-1 font-display text-xl font-bold text-paper sm:text-2xl dark:text-ink">{label}</p>
</div>
