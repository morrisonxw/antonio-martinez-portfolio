---
import Container from '../ui/Container.astro';
import { site } from '../../content-data/site';

const year = new Date().getFullYear();
---

<footer class="border-t border-border py-10">
  <Container class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <p class="text-sm text-ink-muted">© {year} {site.name}. Todos los derechos reservados.</p>
    <div class="flex items-center gap-4 text-sm text-ink-muted">
      <a href={`mailto:${site.email}`} class="hover:text-accent">{site.email}</a>
      <a href={site.social.linkedin} class="hover:text-accent" target="_blank" rel="noopener noreferrer">LinkedIn</a>
    </div>
  </Container>
</footer>
