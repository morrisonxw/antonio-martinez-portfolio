---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import Nav from './Nav.astro';
import ThemeToggle from '../islands/ThemeToggle';
import { site } from '../../content-data/site';
---

<header class="border-b border-border py-5 sm:py-6">
  <Container class="flex flex-wrap items-center justify-between gap-x-4 gap-y-3">
    <a href="/" class="shrink-0 whitespace-nowrap font-display text-lg font-bold text-ink">
      {site.name}
    </a>
    <div class="flex flex-wrap items-center gap-x-4 gap-y-3 sm:gap-x-6">
      <Nav />
      <Button
        href="/cv/Antonio-Martinez-CV.pdf"
        download
        variant="secondary"
        class="px-3 text-xs sm:px-5 sm:text-sm"
      >
        <span class="sm:hidden">CV</span>
        <span class="hidden sm:inline">Descargar CV</span>
      </Button>
      <ThemeToggle client:load />
    </div>
  </Container>
</header>
