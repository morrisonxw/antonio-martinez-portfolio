---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary';
  class?: string;
  download?: boolean | string;
  target?: string;
  rel?: string;
}

const { href, variant = 'primary', class: className = '', ...rest } = Astro.props;
const Tag = href ? 'a' : 'button';

const base =
  'inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium transition-colors';
const variants = {
  primary: 'bg-ink text-paper hover:bg-accent dark:bg-paper dark:text-ink',
  secondary: 'border border-border text-ink hover:border-accent hover:text-accent',
};
---

<Tag href={href} class:list={[base, variants[variant], className]} {...rest}>
  <slot />
</Tag>
