---
interface Props {
  eyebrow?: string;
  class?: string;
}

const { eyebrow, class: className = '' } = Astro.props;
---

<div class:list={['max-w-[var(--prose-width)]', className]}>
  {eyebrow && <p class="mb-2 text-sm font-medium text-accent">{eyebrow}</p>}
  <h2 class="font-display text-3xl font-bold text-ink sm:text-4xl">
    <slot />
  </h2>
</div>
