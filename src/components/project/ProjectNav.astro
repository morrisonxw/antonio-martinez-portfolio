---
import type { CollectionEntry } from 'astro:content';

interface Props {
  prev?: CollectionEntry<'projects'>;
  next?: CollectionEntry<'projects'>;
}

const { prev, next } = Astro.props;
---

<nav aria-label="Navegación entre proyectos" class="grid grid-cols-1 gap-4 border-t border-border pt-8 sm:grid-cols-2">
  {
    prev ? (
      <a href={`/proyectos/${prev.id}`} class="group">
        <span class="text-xs font-medium uppercase tracking-wide text-ink-muted">Anterior</span>
        <p class="mt-1 font-display text-lg font-semibold text-ink group-hover:text-accent">{prev.data.title}</p>
      </a>
    ) : (
      <span />
    )
  }
  {
    next && (
      <a href={`/proyectos/${next.id}`} class="text-right group sm:text-right">
        <span class="text-xs font-medium uppercase tracking-wide text-ink-muted">Siguiente</span>
        <p class="mt-1 font-display text-lg font-semibold text-ink group-hover:text-accent">{next.data.title}</p>
      </a>
    )
  }
</nav>
